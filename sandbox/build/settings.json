//empty objects or arrays will be ignored by the parser because it cannot interpret the type of the nested value

{
    //if debug is false, the Vulkan Debug Callback will not be assigned and debug_layers will be ignored
    "debug" : true,
    //all debug (validation) layers whose valid string interpretation is listed here will be loaded 
    "debug_layers" : ["VK_LAYER_KHRONOS_validation"],

    "metadata" : {
        "application_data" : {
            //internal app name, *not window title*
            "name" : "sandbox",
            //internal app version
            "version" : [0, 0, 0]
        }
    },

    "presentation" : {
        "window" : {
            "title" : "Alcubierre sandbox app",
            //size of the window, also size of the framebuffer by default
            "width" : 800,
            "height" : 600,
            //if true, above window size values are ignored 
            "maximised" : false,
            //if true, the user may freely resize the window in their compositor. may result in significant performance issues on some systems (namely wayland)
            "permit_resize" : false
        }
    },

    "renderer" : {
        //if true, does not initialise the renderchain (graphics pipeline, shader modules, swapchain, command pools) until the first frame draw command is recieved
        "defer_renderchain_initialisation" : false,
        //all vulkan *instance* extensions whose valid string interpretation is listed here will be loaded
        "extensions" : ["VK_EXT_debug_utils"]
    },

    "graphics" : {
        "device" : {
            //all vulkan *device* extensions whose valid string interpretation is listed here will be loaded
            "extensions" : []
        },
        //the first vulkan image format whose enumerative representative is listed here and is supported by the window surface will be used. refer to below api reference for enum codes
        //https://docs.vulkan.org/refpages/latest/refpages/source/VkFormat.html
        "acceptable_image_formats" : [50],
        //the first presentation mode listed here which is found to be compatible will be used. valid modes are immediate, triple_buffered, vsync and relaxed_vsync
        "acceptable_presentation_modes" : ["vsync", "immediate"],
        "max_frames_in_flight" : 2,
        //rendering command timeout
        "command_timeout_seconds" : 5,
        "vertex_buffer_memory_size_bytes" : 10000000
    }
}